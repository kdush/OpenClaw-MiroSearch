# ===============================
# OpenClaw-MiroSearch Compose 环境变量示例
# 使用方法：
# cp .env.compose.example .env.compose
# docker compose --env-file .env.compose up -d --build
# ===============================

# 对外端口
APP_PORT=8080
API_PORT=8090
SEARXNG_HOST_PORT=27080
SEARXNG_PUBLIC_BASE_URL=http://localhost:27080/

# LLM 网关（OpenAI 兼容）
BASE_URL=https://api.longcat.chat/openai
API_KEY=replace_with_your_api_key
# 多 Key 轮转（逗号分隔，429 时自动切换到下一 Key）
# OPENAI_API_KEYS=sk-key1,sk-key2,sk-key3
DEFAULT_LLM_PROVIDER=openai
DEFAULT_MODEL_NAME=LongCat-Flash-Chat
MODEL_TOOL_NAME=LongCat-Flash-Chat
MODEL_FAST_NAME=LongCat-Flash-Lite
MODEL_THINKING_NAME=LongCat-Flash-Thinking-2601
MODEL_SUMMARY_NAME=LongCat-Flash-Lite
# 备用模型：主模型连续失败时自动切换（留空则不启用 failback）
# 推荐配置同一 provider 下更稳/更小的模型作为 fallback，避免单点不稳定。
# 例：OpenRouter -> qwen/qwen3.5-35b-a3b 或 openai/gpt-4o-mini
MODEL_FALLBACK_NAME=

# LLM 调用兜底超时（秒）：单次 LLM 请求总墙时上限，覆盖 SDK 内部 timeout/retry。
# 留空则使用代码默认值 480；建议保持默认或在网络稳定时下调到 300。
# LLM_CALL_WALL_TIMEOUT_SECONDS=480

# 默认策略
DEFAULT_RESEARCH_MODE=balanced
DEFAULT_SEARCH_PROFILE=parallel-trusted
DEFAULT_SEARCH_RESULT_NUM=20
SEARCH_RESULT_DISPLAY_MAX=30
DEFAULT_VERIFICATION_MIN_SEARCH_ROUNDS=3

# Demo 后端模式（断电重连开关）
#   local：默认。pipeline 在 gradio-demo 进程内执行，刷新即丢失。
#   api  ：每个检索为 api-server 上的一个任务；URL ?task_id=xxx 支持
#          页面刷新 / 断电后重连 SSE 续看进度。
#          需配套 api/worker/valkey 服务（compose 已默认包含）。
BACKEND_MODE=api
# host-network 模式下使用本机 API 端口；端口映射模式可写 http://api:8090
API_BASE_URL=http://127.0.0.1:8090
# 可选 Bearer Token（api-server 端启用鉴权时填写）
# API_BEARER_TOKEN=

# 搜索引擎（可多路）
# 未显式设置 SEARXNG_BASE_URL 时，compose 默认指向内置 searxng 服务
# SEARXNG_BASE_URL=http://searxng:8080
SERPAPI_API_KEY=replace_with_your_serpapi_api_key
# SERPAPI_API_KEYS=key1,key2
SERPER_API_KEY=replace_with_your_serper_api_key
# SERPER_API_KEYS=key1,key2,key3
SERPER_BASE_URL=https://google.serper.dev
# Tavily：为 LLM/Agent 优化的搜索 SaaS，1000 次/月免费，作为第四路商业源
TAVILY_API_KEY=
# TAVILY_API_KEYS=key1,key2
# TAVILY_SEARCH_DEPTH=basic   # basic（1 credit/次）或 advanced（2 credits/次）

# 可选工具 API（如未使用，可留空）
JINA_API_KEY=
JINA_BASE_URL=https://r.jina.ai
E2B_API_KEY=
TENCENTCLOUD_SECRET_ID=
TENCENTCLOUD_SECRET_KEY=

# 检索路由策略（可选）
# 配置 TAVILY_API_KEY 后，可把 tavily 加入 ORDER 与 TRUSTED_ORDER：
#   SEARCH_PROVIDER_ORDER=serpapi,tavily,searxng,serper
#   SEARCH_PROVIDER_TRUSTED_ORDER=serpapi,tavily,searxng,serper
SEARCH_PROVIDER_ORDER=serpapi,searxng,serper
SEARCH_PROVIDER_MODE=parallel_conf_fallback
SEARCH_PROVIDER_TRUSTED_ORDER=serpapi,searxng,serper
SEARCH_PROVIDER_PARALLEL_MAX_WAIT_MS=4500
SEARCH_PROVIDER_PARALLEL_MIN_SUCCESS=1
SEARCH_PROVIDER_FALLBACK_MAX_STEPS=3
SEARCH_RESULT_NUM=20
SEARCH_CONFIDENCE_ENABLED=1
SEARCH_CONFIDENCE_SCORE_THRESHOLD=0.62
SEARCH_CONFIDENCE_MIN_RESULTS=8
SEARCH_CONFIDENCE_MIN_UNIQUE_DOMAINS=5
SEARCH_CONFIDENCE_MIN_PROVIDER_COVERAGE=2
SEARCH_CONFIDENCE_MIN_HIGH_CONF_HITS=2
SEARCH_CONFIDENCE_HIGH_CONF_DOMAINS=reuters.com,apnews.com,bbc.com,aljazeera.com,state.gov,un.org,iaea.org,who.int

# Valkey/Redis 配置（异步任务队列）
VALKEY_HOST=valkey
VALKEY_PORT=6379
VALKEY_PASSWORD=
TASK_QUEUE_REDIS_DB=1
TASK_STORE_REDIS_DB=2
TASK_QUEUE_NAME=miro:research:queue
TASK_EVENT_STREAM_MAXLEN=1000
TASK_RESULT_TTL_SECONDS=3600
TASK_METADATA_TTL_SECONDS=7200
ARQ_JOB_TIMEOUT_SECONDS=1800
ARQ_WORKER_MAX_JOBS=1
TASK_CANCEL_POLL_INTERVAL_SECONDS=0.5
