# API Server 配置
API_HOST=0.0.0.0
API_PORT=8090

# Bearer Token 认证（逗号分隔，留空则跳过认证）
API_TOKENS=

# 请求限流（滑动窗口，每分钟最大请求数）
RATE_LIMIT_ENABLED=1
RATE_LIMIT_RPM=30

# 结果缓存
RESULT_CACHE_MAX_SIZE=128
RESULT_CACHE_TTL_SECONDS=3600

# Agent 配置目录（默认自动检测）
# AGENT_CONF_DIR=/path/to/conf

# Agent 和 LLM 配置名
AGENT_CONFIG=mirothinker_v1.5_keep5_max200
LLM_CONFIG=qwen-3

# 日志目录
LOG_DIR=logs/api-server

# LLM 网关（继承自 miroflow-agent 的配置）
BASE_URL=https://api.longcat.chat/openai
API_KEY=your_api_key
DEFAULT_LLM_PROVIDER=openai
DEFAULT_MODEL_NAME=your_default_model
MODEL_TOOL_NAME=your_tool_model
MODEL_FAST_NAME=your_fast_model
MODEL_THINKING_NAME=your_thinking_model
MODEL_SUMMARY_NAME=your_summary_model
MODEL_FALLBACK_NAME=
